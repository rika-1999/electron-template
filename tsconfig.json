{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/main/**/*",
    "src/preload/**/*",
    "src/shared/**/*",
    "src/utils/**/*",
    "src/vite-plugins/**/*",
    "scripts/**/*",
    "vite.config*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "release"
  ],
  "references": [
    { "path": "./tsconfig.renderer.json" }
  ]
}
