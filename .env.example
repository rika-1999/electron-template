# Auto-update server URL (generic provider)
UPDATE_SERVER_URL=http://localhost:8888

# Whether to check for updates on startup (default: true)
AUTO_CHECK_ON_STARTUP=true

# Whether to automatically download updates when found (default: false)
AUTO_DOWNLOAD=false

# Update check interval in milliseconds (default: 3600000 = 1h, 0 = disabled)
UPDATE_CHECK_INTERVAL=3600000
