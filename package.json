{
  "name": "electron-template",
  "version": "1.0.0",
  "description": "Electron + React + TypeScript desktop application",
  "license": "MIT",
  "main": "dist/main/index.js",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build:dev": "node scripts/build.mjs",
    "start": "concurrently -k \"vite --config vite.config.renderer.ts\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "dev": "pnpm run build:dev && pnpm run start",
    "build": "cross-env NODE_ENV=production node scripts/build.mjs",
    "package": "pnpm run build && electron-builder",
    "package:win": "pnpm run build && electron-builder --win",
    "lint": "eslint src",
    "test": "vitest run",
    "test:main": "vitest run --project main",
    "test:renderer": "vitest run --project renderer",
    "test:preload": "vitest run --project preload"
  },
  "build": {
    "extends": "electron-builder.config.mjs"
  },
  "dependencies": {
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.0",
    "force": "^0.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vite-plugin-static-copy": "^3.3.0",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.0"
  }
}
