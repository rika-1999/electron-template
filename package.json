{
  "name": "electron-template",
  "version": "1.0.0",
  "description": "Electron + React + TypeScript desktop application",
  "author": "",
  "license": "MIT",
  "repository": "",
  "main": "dist/main/index.js",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build:native": "pnpm --filter native run build",
    "build": "pnpm run build:native && cross-env NODE_ENV=production node scripts/build.mjs",
    "package": "pnpm run build && electron-builder",
    "package:win": "pnpm run build && electron-builder --win",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "typecheck": "tsc --build",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:main": "vitest run --project main",
    "test:renderer": "vitest run --project renderer",
    "test:preload": "vitest run --project preload",
    "test:e2e": "pnpm run build && playwright test",
    "test:e2e:debug": "pnpm run build && playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "build": {
    "extends": "electron-builder.config.mjs"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-log": "~5.2.0",
    "electron-updater": "~6.8.3",
    "lucide-react": "^1.7.0",
    "native": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "~1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/node": "~20.16.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "~8.57.0",
    "@typescript-eslint/parser": "~8.57.0",
    "@vitejs/plugin-react": "~4.3.0",
    "@vitest/coverage-v8": "~3.2.4",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "34.0.0",
    "electron-builder": "~26.8.0",
    "esbuild": "~0.24.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-playwright": "~2.10.1",
    "jsdom": "^26.0.0",
    "msw": "^2.12.14",
    "prettier": "^3.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.2",
    "tsx": "~4.19.0",
    "typescript": "~5.5.0",
    "typescript-eslint": "~8.57.0",
    "vite": "~5.4.0",
    "vite-plugin-static-copy": "~3.3.0",
    "vitest": "~3.2.4",
    "wait-on": "^8.0.0"
  }
}