{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2021",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react-jsx",
    "composite": true,
    "declaration": true,
    "declarationDir": "./dist/types/renderer",
    "emitDeclarationOnly": true,
    "types": [
      "vitest/globals"
    ]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "src/main/**/*",
    "src/__tests__/main/**/*",
    "node_modules",
    "dist",
    "release"
  ]
}