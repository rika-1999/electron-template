{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "composite": true,
    "emitDeclarationOnly": true,
    "types": ["vitest/globals"]
  },
  "include": [
    "src/renderer/**/*",
    "src/test/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "release"
  ]
}
